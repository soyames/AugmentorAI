# ────────────────────── Required ──────────────────────
# At least one AI provider key is needed for the app to work

# DeepSeek API key (recommended primary)
# Get yours at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# Gemini API key (fallback AI provider)
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key-here

# Hermes API key (for Hermes-powered features)
# Get yours at: https://ai.digitalconcordia.com/settings
HERMES_API_KEY=your-hermes-key-here

# ────────────────────── Optional ──────────────────────

# Server port (default: 8010)
AUGMENTOR_API_PORT=8010

# Web UI port (default: 8080)
AUGMENTOR_WEB_PORT=8080

# Default LLM model for local inference
AUGMENTOR_DEFAULT_MODEL=qwen2.5-coder:3b

# Ollama URL (for local models)
AUGMENTOR_OLLAMA_URL=http://127.0.0.1:11434

# CORS allowed origins
AUGMENTOR_CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
