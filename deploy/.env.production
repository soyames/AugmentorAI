# AugmentorAI - production environment template
# Copy this to server/.env for deployment.
# Do not put cloud LLM API keys in this committed template.
# Add Gemini and DeepSeek keys from the in-app Settings screen.

# ===== LLM Configuration =====
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.0-flash

DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Ollama local fallback
OLLAMA_URL=http://127.0.0.1:11434
DEFAULT_MODEL=qwen2.5-coder:3b
LLM_PROVIDER_ORDER=gemini,deepseek,ollama

# ===== CORS =====
# Comma-separated list of allowed origins
CORS_ORIGINS=https://augmentor.digitalconcordia.com,https://ai.digitalconcordia.com

# ===== Database =====
# Default: SQLite at server/data/augmentor.db
# Uncomment for PostgreSQL:
# DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/augmentorai
