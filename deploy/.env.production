# AugmentorAI — Production environment template
# Copy this to server/.env and fill in the values
# NEVER commit the actual .env file!

# ===== LLM Configuration =====

# DeepSeek API (primary LLM — cheap, high quality)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Ollama local fallback (free, always available)
OLLAMA_URL=http://127.0.0.1:11434
DEFAULT_MODEL=qwen2.5-coder:3b

# ===== CORS =====
# Comma-separated list of allowed origins
CORS_ORIGINS=https://augmentor.digitalconcordia.com,https://ai.digitalconcordia.com

# ===== Database =====
# Default: SQLite at server/data/augmentor.db
# Uncomment for PostgreSQL:
# DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/augmentorai
