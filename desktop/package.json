{
  "name": "augmentor-ai-desktop",
  "version": "1.0.0",
  "description": "AugmentorAI Desktop Application",
  "main": "src/main.js",
  "scripts": {
    "dev": "electron .",
    "prebuild": "npm --prefix ../web run build",
    "build": "electron-builder --publish never",
    "build:win": "npm run prebuild && electron-builder --win --publish never",
    "build:mac": "npm run prebuild && electron-builder --mac --publish never",
    "build:linux": "npm run prebuild && electron-builder --linux --publish never"
  },
  "build": {
    "appId": "com.augmentorai.app",
    "productName": "AugmentorAI",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "node_modules/**/*",
      {
        "from": "../web/dist",
        "to": "web-dist"
      }
    ],
    "extraResources": [
      {
        "from": "../server/dist/server_backend.exe",
        "to": "server_backend.exe"
      }
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "soyames",
        "repo": "AugmentorAI"
      }
    ]
  },
  "devDependencies": {
    "electron": "28.2.0",
    "electron-builder": "^24.9.1"
  }
}
