{
  "name": "augmentor-ai",
  "version": "1.0.0",
  "description": "AI-powered interview practice and preparation copilot",
  "private": true,
  "workspaces": [
    "web",
    "desktop",
    "shared"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=web",
    "dev:desktop": "npm run dev --workspace=desktop",
    "dev:server": "server\\.venv\\Scripts\\python.exe -m uvicorn app.main:app --reload --port 8010 --app-dir server",
    "build:web": "npm run build --workspace=web",
    "build:desktop": "npm run build --workspace=desktop",
    "start": "concurrently \"npm run dev:server\" \"npm run dev:web\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
